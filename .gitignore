**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production
**/.env.production.local

**/local.settings.*
!**/local.settings.example.json

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# build output
frontend/build/

# dependencies
frontend/.pnp
