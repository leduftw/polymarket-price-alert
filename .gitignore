__azurite_db_*
__blobstorage__
__queuestorage__
__tablestorage__

# ignore everything under .vscode...
.vscode/*

# but keep these project‑wide files
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
